@inherits LayoutComponentBase

<MudThemeProvider Theme="_ciTheme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudText Typo="Typo.h6" Class="ml-3">Einsatzführungsboard – Etiketten-Generator</MudText>
    </MudAppBar>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mb-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private readonly MudTheme _ciTheme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#000548",
            Secondary = "#4a6fb8",
            Error = "#eb003c",
            Success = "#2f8f68",
            Warning = "#dee100",
            GrayLight = "#c7ccd9",
            Surface = "#ffffff",
            Background = "#ffffff",
        }
    };
}
